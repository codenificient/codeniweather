# CodeniWeather Environment Configuration
# Copy this file to .env.local and fill in your actual API keys

# =============================================================================
# REQUIRED
# =============================================================================

# OpenWeatherMap API Key (weather data + reverse geocoding)
# Get your free API key from: https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# MapTiler API Key (maps + forward geocoding)
# Get your free API key from: https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_API_KEY=your_maptiler_api_key_here

# =============================================================================
# ANALYTICS (optional — defaults are provided)
# =============================================================================

# Client-side analytics SDK
NEXT_PUBLIC_ANALYTICS_API_KEY=proj_codeniweather_main
NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://codenalytics.vercel.app
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Server-side analytics (used by API routes)
ANALYTICS_API_KEY=proj_codeniweather_main
ANALYTICS_ENDPOINT=https://codenalytics.vercel.app/api

# =============================================================================
# OPTIONAL
# =============================================================================

# IP Geolocation API (alternative to OpenWeatherMap geocoding)
# Get from: https://ipapi.co/api/
# NEXT_PUBLIC_IPAPI_KEY=your_ipapi_key_here

# Weather Alerts API (for severe weather notifications)
# Get from: https://openweathermap.org/api/one-call-3
# NEXT_PUBLIC_WEATHER_ALERTS_API_KEY=your_weather_alerts_key_here

# API Configuration
# NEXT_PUBLIC_OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Cache Settings — weather data cache duration in minutes (default: 10)
# NEXT_PUBLIC_CACHE_DURATION=10

# Rate Limiting — maximum API calls per minute (default: 60)
# NEXT_PUBLIC_RATE_LIMIT=60

# =============================================================================
# DEVELOPMENT
# =============================================================================
NODE_ENV=development
